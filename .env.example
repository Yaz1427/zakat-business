# ============================================================================
# ZAKAT BUSINESS — ENVIRONMENT VARIABLES TEMPLATE
# ============================================================================
# Copy this file to .env.local (dev) or configure on Vercel/production
# IMPORTANT: Update NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL to /calculateur (not /dashboard/history)

# ────────────────────────────────────────────────────────────────────────────
# DATABASE
# ────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@neon.tech/zakat-db
DIRECT_URL=postgresql://user:password@neon.tech/zakat-db

# ────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION (Clerk)
# ────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/calculateur
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/calculateur

# ────────────────────────────────────────────────────────────────────────────
# STRIPE PAYMENTS
# ────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_CABINET=price_...

# ────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://zakatbusiness.com
ADMIN_SECRET=your-strong-random-secret
